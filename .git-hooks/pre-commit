#!/bin/bash
# anti-hallucination-guard -- pre-commit hook
# Blocks commit if worklog.md is not updated.
# Checks integrity of hooks and configuration (anti-tampering).
# Automatically installed by setup.sh.
# Other modules (cascade-guard, verify-docs) may append checks after this block.

WORKLOG="worklog.md"
MAX_AGE=600  # 10 minutes

# Cross-platform stat: Linux uses -c, macOS uses -f
get_mtime() {
    stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null
}

# ---- Phase 1: Integrity check (anti-tampering) ----

# NOTE: If core.hooksPath is set, this hook is NEVER CALLED by Git.
# The check below only catches accidental misconfiguration when the hook
# is run manually. For real enforcement, use CI + branch protection rules.
# The pre-push hook and validate.sh also check hooksPath.
HP=$(git config --get core.hooksPath 2>/dev/null || echo "")
if [ -n "$HP" ]; then
    echo ""
    echo "  ERROR: core.hooksPath is set to '$HP'"
    echo "  This bypasses the standard hooks directory."
    echo "  Unset it: git config --unset core.hooksPath"
    echo ""
    exit 1
fi

# Quick self-check: this hook must contain "worklog" check
# (catches trivial replacement like "echo '# bypass' > pre-commit")
if ! grep -q "WORKLOG" "$0" 2>/dev/null; then
    # This shouldn't happen -- we ARE the worklog check
    # But if the hook was replaced and this is running, it's a sign of tampering
    echo ""
    echo "  ERROR: pre-commit hook appears to be tampered with"
    echo "  (self-check failed: hook does not contain expected patterns)"
    echo "  Re-install: bash anti-hallucination-guard/setup.sh"
    echo ""
    exit 1
fi

# ---- Phase 2: Worklog checks ----

# 1. Check existence
if [ ! -f "$WORKLOG" ]; then
    echo ""
    echo "  ERROR: worklog.md not found!"
    echo "  Create the file and describe the work done."
    echo ""
    exit 1
fi

# 2. Check freshness
LAST_MODIFIED=$(get_mtime "$WORKLOG")
NOW=$(date +%s)
DIFF=$((NOW - LAST_MODIFIED))

if [ "$DIFF" -gt "$MAX_AGE" ]; then
    echo ""
    echo "  ERROR: worklog.md not updated for over $((MAX_AGE/60)) minutes!"
    echo "  Last update: $((DIFF/60)) min ago"
    echo "  Update worklog.md before committing."
    echo ""
    exit 1
fi

# 3. Check minimum size
SIZE=$(wc -c < "$WORKLOG")
if [ "$SIZE" -lt 50 ]; then
    echo ""
    echo "  ERROR: worklog.md is empty (less than 50 bytes)!"
    echo "  Describe the work done."
    echo ""
    exit 1
fi

# 4. Check for standard blocks
BLOCK_COUNT=$(grep -c '^---$' "$WORKLOG" 2>/dev/null)
if [ "$BLOCK_COUNT" -lt 2 ]; then
    echo ""
    echo "  ERROR: worklog.md does not contain standard blocks!"
    echo "  Format: --- / Task ID / Work Log / Stage Summary / ---"
    echo ""
    exit 1
fi

echo "  OK: worklog.md is up to date ($BLOCK_COUNT blocks)"

# ---- Phase 2.5: sync-task-state (cascade-state auto-sync) ----
if [ -f "cascade-state.json" ] && [ -f "scripts/sync-task-state.sh" ]; then
    bash scripts/sync-task-state.sh 2>&1
    SYNC_RESULT=$?
    if [ $SYNC_RESULT -ne 0 ]; then
        echo ""
        echo "  WARN: sync-task-state reported issues"
        echo "  (non-blocking -- check cascade-state.json)"
        echo ""
    fi
fi

# ---- Phase 3: verify-docs (if configured) ----
# Runs verify-docs on pre-commit if verify-docs.json exists
# This catches doc drift BEFORE it gets committed (not just at push)

if [ -f "verify-docs.json" ]; then
    if command -v bun &>/dev/null; then
        # Find verify-docs CLI
        VD_CLI=""
        if [ -f "anti-hallucination-guard/tools/verify-docs/src/cli.ts" ]; then
            VD_CLI="anti-hallucination-guard/tools/verify-docs/src/cli.ts"
        elif [ -f "tools/verify-docs/src/cli.ts" ]; then
            VD_CLI="tools/verify-docs/src/cli.ts"
        fi
        
        if [ -n "$VD_CLI" ]; then
            echo "  Running verify-docs (pre-commit check)..."
            bun run "$VD_CLI" --ci 2>&1
            VD_RESULT=$?
            if [ $VD_RESULT -ne 0 ]; then
                echo ""
                echo "  ERROR: verify-docs found mismatches!"
                echo "  Fix documentation before committing."
                echo "  Or bypass with: git commit --no-verify (NOT recommended)"
                echo ""
                exit 1
            fi
            echo "  OK: verify-docs passed"
        fi
    fi
fi

# ---- Phase 3.5: auto-discover fallback (if no verify-docs.json) ----
if [ ! -f "verify-docs.json" ] && command -v bun &>/dev/null; then
    VD_CLI=""
    if [ -f "anti-hallucination-guard/tools/verify-docs/src/cli.ts" ]; then
        VD_CLI="anti-hallucination-guard/tools/verify-docs/src/cli.ts"
    elif [ -f "tools/verify-docs/src/cli.ts" ]; then
        VD_CLI="tools/verify-docs/src/cli.ts"
    fi
    if [ -n "$VD_CLI" ]; then
        echo "  No verify-docs.json -- running auto-discover..."
        bun run "$VD_CLI" --discover 2>&1
        DISCOVER_RESULT=$?
        if [ $DISCOVER_RESULT -ne 0 ]; then
            echo ""
            echo "  ERROR: auto-discover found issues!"
            echo "  Fix or create verify-docs.json: bun run $VD_CLI --init"
            echo ""
            exit 1
        fi
        echo "  OK: auto-discover passed"
    fi
fi

# NOTE: Do NOT add 'exit 0' here.
# Other modules (cascade-guard, verify-docs) append their checks after this block.
