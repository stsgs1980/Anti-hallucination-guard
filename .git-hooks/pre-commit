#!/bin/bash
# anti-hallucination-guard -- pre-commit hook
# Blocks commit if worklog.md is not updated.
# Checks integrity of hooks and configuration (anti-tampering).
# Automatically installed by setup.sh.
# Other modules (cascade-guard, verify-docs) may append checks after this block.

WORKLOG="worklog.md"
MAX_AGE=600  # 10 minutes

# Cross-platform stat: Linux uses -c, macOS uses -f
get_mtime() {
    stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null
}

# ---- Phase 1: Integrity check (anti-tampering) ----

# NOTE: If core.hooksPath is set, this hook is NEVER CALLED by Git.
# The check below only catches accidental misconfiguration when the hook
# is run manually. For real enforcement, use CI + branch protection rules.
# The pre-push hook and validate.sh also check hooksPath.
HP=$(git config --get core.hooksPath 2>/dev/null || echo "")
if [ -n "$HP" ]; then
    echo ""
    echo "  ERROR: core.hooksPath is set to '$HP'"
    echo "  This bypasses the standard hooks directory."
    echo "  Unset it: git config --unset core.hooksPath"
    echo ""
    exit 1
fi

# Quick self-check: this hook must contain "worklog" check
# (catches trivial replacement like "echo '# bypass' > pre-commit")
if ! grep -q "WORKLOG" "$0" 2>/dev/null; then
    # This shouldn't happen -- we ARE the worklog check
    # But if the hook was replaced and this is running, it's a sign of tampering
    echo ""
    echo "  ERROR: pre-commit hook appears to be tampered with"
    echo "  (self-check failed: hook does not contain expected patterns)"
    echo "  Re-install: bash anti-hallucination-guard/setup.sh"
    echo ""
    exit 1
fi

# ---- Phase 2: Worklog checks ----

# 1. Check existence
if [ ! -f "$WORKLOG" ]; then
    echo ""
    echo "  ERROR: worklog.md not found!"
    echo "  Create the file and describe the work done."
    echo ""
    exit 1
fi

# 2. Check freshness
LAST_MODIFIED=$(get_mtime "$WORKLOG")
NOW=$(date +%s)
DIFF=$((NOW - LAST_MODIFIED))

if [ "$DIFF" -gt "$MAX_AGE" ]; then
    echo ""
    echo "  ERROR: worklog.md not updated for over $((MAX_AGE/60)) minutes!"
    echo "  Last update: $((DIFF/60)) min ago"
    echo "  Update worklog.md before committing."
    echo ""
    exit 1
fi

# 3. Check minimum size
SIZE=$(wc -c < "$WORKLOG")
if [ "$SIZE" -lt 50 ]; then
    echo ""
    echo "  ERROR: worklog.md is empty (less than 50 bytes)!"
    echo "  Describe the work done."
    echo ""
    exit 1
fi

# 4. Check for standard blocks
BLOCK_COUNT=$(grep -c '^---$' "$WORKLOG" 2>/dev/null)
if [ "$BLOCK_COUNT" -lt 2 ]; then
    echo ""
    echo "  ERROR: worklog.md does not contain standard blocks!"
    echo "  Format: --- / Task ID / Work Log / Stage Summary / ---"
    echo ""
    exit 1
fi

echo "  OK: worklog.md is up to date ($BLOCK_COUNT blocks)"

# ---- Phase 2.5: sync-task-state (cascade-state auto-sync) ----
if [ -f "cascade-state.json" ] && [ -f "scripts/sync-task-state.sh" ]; then
    bash scripts/sync-task-state.sh 2>&1
    SYNC_RESULT=$?
    if [ "$SYNC_RESULT" -ne 0 ]; then
        echo ""
        echo "  WARN: sync-task-state reported issues"
        echo "  (non-blocking -- check cascade-state.json)"
        echo ""
    fi
fi

# ---- Phase 3: verify-docs (if configured) ----
# Runs verify-docs on pre-commit if verify-docs.json exists
# This catches doc drift BEFORE it gets committed (not just at push)
#
# Find the AHG module directory (same discovery logic as pre-push hook).
# We can NOT rely on hardcoded paths like "anti-hallucination-guard/tools/..."
# because the AHG module may be at any path (vendor/, lib/, custom name).

_pc_git_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
_pc_ahg_dir=""

# Check .gitmodules for AHG submodule
if [ -f "$_pc_git_root/.gitmodules" ]; then
    _pc_sp=$(git -C "$_pc_git_root" config -f .gitmodules --get-regexp 'path' 2>/dev/null \
        | grep -i 'anti.hallucination' | awk '{print $2}' | head -1 || true)
    if [ -n "$_pc_sp" ] && [ -f "$_pc_git_root/$_pc_sp/setup.sh" ]; then
        _pc_ahg_dir="$_pc_git_root/$_pc_sp"
    fi
fi

# Check common locations
if [ -z "$_pc_ahg_dir" ]; then
    for _pc_c in \
        "$_pc_git_root/anti-hallucination-guard" \
        "$_pc_git_root/vendor/anti-hallucination-guard" \
        "$_pc_git_root/lib/anti-hallucination-guard"; do
        if [ -d "$_pc_c" ] && [ -f "$_pc_c/setup.sh" ]; then
            _pc_ahg_dir="$_pc_c"
            break
        fi
    done
fi

# Check if we ARE the AHG module repo (standalone)
if [ -z "$_pc_ahg_dir" ] && [ -f "$_pc_git_root/setup.sh" ] && [ -f "$_pc_git_root/AGENT_RULES.md" ]; then
    _pc_ahg_dir="$_pc_git_root"
fi

# Resolve verify-docs CLI path from the discovered AHG module
VD_CLI=""
if [ -n "$_pc_ahg_dir" ] && [ -f "$_pc_ahg_dir/tools/verify-docs/src/cli.ts" ]; then
    VD_CLI="$_pc_ahg_dir/tools/verify-docs/src/cli.ts"
fi

if [ -f "verify-docs.json" ]; then
    if command -v bun &>/dev/null && [ -n "$VD_CLI" ]; then
        echo "  Running verify-docs (pre-commit check)..."
        bun run "$VD_CLI" --ci 2>&1
        VD_RESULT=$?
        if [ "$VD_RESULT" -ne 0 ]; then
            echo ""
            echo "  ERROR: verify-docs found mismatches!"
            echo "  Fix documentation before committing."
            echo "  Or bypass with: git commit --no-verify (NOT recommended)"
            echo ""
            exit 1
        fi
        echo "  OK: verify-docs passed"
    fi
fi

# ---- Phase 3.5: auto-discover fallback (if no verify-docs.json) ----
if [ ! -f "verify-docs.json" ] && command -v bun &>/dev/null && [ -n "$VD_CLI" ]; then
    echo "  No verify-docs.json -- running auto-discover..."
    bun run "$VD_CLI" --discover 2>&1
    DISCOVER_RESULT=$?
    if [ "$DISCOVER_RESULT" -ne 0 ]; then
        echo ""
        echo "  [WARN] auto-discover found issues (not blocking):"
        echo "  Fix or create verify-docs.json: bun run $VD_CLI --init"
        echo "  To enforce: run 'bun run $VD_CLI --init' and commit verify-docs.json"
        echo ""
    fi
    echo "  OK: auto-discover passed"
fi

# ---- Phase 4: Anti-monolith check (Rule 12 enforcement) ----
# Checks that no source file exceeds the line limit (default: 250).
# Configurable via env: LINE_LIMIT, LINE_CHECK_DIR, LINE_CHECK_GLOB, LINE_CHECK_SKIP.
# Looks for the script in: project scripts/, AHG module scripts/, or common paths.

_lc_script=""
# 1. Project-level scripts/ (deployed by setup.sh)
if [ -f "scripts/line-count-check.sh" ]; then
    _lc_script="scripts/line-count-check.sh"
# 2. AHG module scripts/ (if running in AHG standalone repo)
elif [ -n "$_pc_ahg_dir" ] && [ -f "$_pc_ahg_dir/scripts/line-count-check.sh" ]; then
    _lc_script="$_pc_ahg_dir/scripts/line-count-check.sh"
fi

if [ -n "$_lc_script" ]; then
    echo "  Running anti-monolith check (Rule 12)..."
    # When AHG is a submodule, only scan the AHG directory -- not the host project.
    # Host project files are not subject to AHG's anti-monolith rule.
    _lc_dir=""
    if [ -n "$_pc_ahg_dir" ] && [ "$_pc_ahg_dir" != "$_pc_git_root" ]; then
        _lc_dir="$_pc_ahg_dir"
    fi
    LINE_CHECK_DIR="$_lc_dir" bash "$_lc_script" 2>&1
    _lc_result=$?
    if [ "$_lc_result" -ne 0 ]; then
        echo ""
        echo "  ERROR: Anti-monolith violations found!"
        echo "  Decompose files to stay under the line limit."
        echo "  Rule 12: one file = one responsibility."
        echo ""
        exit 1
    fi
else
    echo "  SKIP: line-count-check.sh not found (Rule 12 enforcement not deployed)"
fi

# ---- Phase 5: Co-change check (buddy file detection) ----
# If file A changes, file B should also change in this commit.
# Config: .ahg-cochange.json in project root.
# Bypass: [no-cochange] in commit message or COCHANGE_BYPASS=1.
#
# Exit codes from co-change-check.sh:
#   0 = pass (all buddies present, or only warn-severity missing)
#   1 = blocked (block-severity violations found)
#   2+ = unexpected error (non-blocking)

_cc_script=""
if [ -f "scripts/co-change-check.sh" ]; then
    _cc_script="scripts/co-change-check.sh"
elif [ -n "$_pc_ahg_dir" ] && [ -f "$_pc_ahg_dir/scripts/co-change-check.sh" ]; then
    _cc_script="$_pc_ahg_dir/scripts/co-change-check.sh"
fi

if [ -n "$_cc_script" ]; then
    echo "  Running co-change check..."
    # Pass commit message for bypass detection (git commit -m support)
    COCHANGE_COMMIT_MSG="" 
    if [ -f "$_pc_git_root/.git/COMMIT_EDITMSG" ]; then
        COCHANGE_COMMIT_MSG=$(cat "$_pc_git_root/.git/COMMIT_EDITMSG" 2>/dev/null || echo "")
    fi
    COCHANGE_COMMIT_MSG="$COCHANGE_COMMIT_MSG" bash "$_cc_script" 2>&1
    _cc_result=$?
    if [ "$_cc_result" -eq 1 ]; then
        # Blocked: block-severity buddy missing
        echo ""
        echo "  ERROR: Co-change violations found!"
        echo "  Missing buddy files in this commit."
        echo "  Add them or use [no-cochange] in commit message."
        echo ""
        exit 1
    elif [ "$_cc_result" -ne 0 ]; then
        # Unexpected error -- warn but don't block
        echo "  WARN: co-change-check exited with code $_cc_result (non-blocking)"
    fi
fi

# NOTE: Do NOT add 'exit 0' here.
# Other modules (cascade-guard, verify-docs) append their checks after this block.
