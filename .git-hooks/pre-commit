#!/bin/bash
# anti-hallucination-guard -- pre-commit hook
# Блокирует commit, если worklog.md не обновлён.
# Автоматически установлен setup.sh.

WORKLOG="worklog.md"
MAX_AGE=600  # 10 минут

# 1. Проверяем существование
if [ ! -f "$WORKLOG" ]; then
    echo ""
    echo "  ОШИБКА: worklog.md не найден!"
    echo "  Создай файл и опиши проделанную работу."
    echo ""
    exit 1
fi

# 2. Проверяем свежесть
LAST_MODIFIED=$(stat -c %Y "$WORKLOG" 2>/dev/null)
NOW=$(date +%s)
DIFF=$((NOW - LAST_MODIFIED))

if [ "$DIFF" -gt "$MAX_AGE" ]; then
    echo ""
    echo "  ОШИБКА: worklog.md не обновлялся более $((MAX_AGE/60)) минут!"
    echo "  Последнее обновление: $((DIFF/60)) мин назад"
    echo "  Обнови worklog.md перед коммитом."
    echo ""
    exit 1
fi

# 3. Проверяем минимальный размер
SIZE=$(wc -c < "$WORKLOG")
if [ "$SIZE" -lt 50 ]; then
    echo ""
    echo "  ОШИБКА: worklog.md пуст (менее 50 байт)!"
    echo "  Опиши проделанную работу."
    echo ""
    exit 1
fi

# 4. Проверяем наличие стандартных блоков
BLOCK_COUNT=$(grep -c '^---$' "$WORKLOG" 2>/dev/null)
if [ "$BLOCK_COUNT" -lt 2 ]; then
    echo ""
    echo "  ОШИБКА: worklog.md не содержит стандартных блоков!"
    echo "  Формат: --- / Task ID / Work Log / Stage Summary / ---"
    echo ""
    exit 1
fi

echo "  OK: worklog.md актуален ($BLOCK_COUNT блоков)"
exit 0
