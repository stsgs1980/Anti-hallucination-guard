#!/bin/bash
# anti-hallucination-guard / pre-push hook
# In AHG module repo: runs validate.sh (purity check).
# In target project: runs ahg.sh verify (doc consistency).
# Install: cp .git-hooks/pre-push .git/hooks/pre-push && chmod +x

set -euo pipefail

# anti-hallucination-guard marker (for setup.sh detection)

MODULE_DIR="$(git rev-parse --show-toplevel)"
SCRIPTS_DIR="$MODULE_DIR/scripts"

# Detect context: are we in the AHG module repo or a target project?
# The AHG module repo has setup.sh in the root.
if [ -f "$MODULE_DIR/setup.sh" ] && [ -f "$MODULE_DIR/AGENT_RULES.md" ] && [ -f "$MODULE_DIR/.git-hooks/pre-commit" ]; then
    # We are in the AHG module repo -- run purity check
    VALIDATE="$SCRIPTS_DIR/validate.sh"
    if [ -f "$VALIDATE" ]; then
        if ! bash "$VALIDATE"; then
            echo ""
            echo "pre-push: PUSH BLOCKED. Repository contains foreign files."
            echo ""
            exit 1
        fi
    fi
else
    # We are in a target project -- run doc consistency check instead
    AHG_SH="$SCRIPTS_DIR/ahg.sh"
    if [ -f "$AHG_SH" ] && command -v bun &>/dev/null; then
        echo "pre-push: Running AHG verify..."
        if ! bash "$AHG_SH" verify --ci 2>&1; then
            echo ""
            echo "pre-push: PUSH BLOCKED. Doc consistency check failed."
            echo ""
            exit 1
        fi
        echo "pre-push: AHG verify passed."
    fi
fi
