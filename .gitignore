# ============================================================
# ANTI-HALLUCINATION-GUARD .gitignore
# STRICT: Only module files should be tracked.
# If git add -A picks up something not in this module, it's a leak.
# validate.sh is the HARD enforcement layer (whitelist check).
# This .gitignore is the SOFT layer (prevents git add -A from staging junk).
# ============================================================

# ---- Whitelist-negative pattern: ignore everything, then allow only ours ----
# This is the strongest protection: git add -A is SAFE because only
# our files can be added. Everything else is ignored.

# First, ignore EVERYTHING
*

# Then, un-ignore our module files
!.gitignore
!README.md
!CHANGELOG.md
!registry.json
!LICENSE
!AGENT_RULES.md
!setup.sh
!setup/
!setup/**
!update.sh

# Co-change dependency graph
!.ahg-cochange.json

# Config file
!.ahgrc

# verify-docs config
!verify-docs.json

# .github directory (CI workflows + CODEOWNERS)
!.github/
!.github/CODEOWNERS
!.github/workflows/
!.github/workflows/*

# .git-hooks directory
!.git-hooks/
!.git-hooks/*

# scripts directory
!scripts/
!scripts/*

# skills directory (only our own)
!skills/
!skills/anti-hallucination-guard/
!skills/anti-hallucination-guard/**

# tools directory
!tools/
!tools/**
!tools/verify-docs/
!tools/verify-docs/**
!tools/verify-docs/src/
!tools/verify-docs/src/**
!tools/verify-docs/templates/
!tools/verify-docs/templates/**
!tools/verify-docs/examples/
!tools/verify-docs/examples/**
!tools/verify-docs/package.json
!tools/verify-docs/CONSUMER_GUIDE.md

# ---- Explicit re-ignore for generated files inside our directories ----
# Even though our directories are un-ignored, these must stay ignored:
tools/verify-docs/node_modules/
bun.lockb
*.bak
*.tmp
*.swp
*.swo
*~
worklog.md
